{
  "version": 2,
  "builds": [
    { "src": "api/download.js",  "use": "@vercel/node" },
    { "src": "api/facebook.py",  "use": "@vercel/python" },
    { "src": "api/youtube.py",   "use": "@vercel/python" },
    { "src": "index.html",       "use": "@vercel/static" },
    { "src": "manifest.json",    "use": "@vercel/static" },
    { "src": "sw.js",            "use": "@vercel/static" },
    { "src": "icon-*.png",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/download", "dest": "/api/download.js" },
    { "src": "/api/facebook", "dest": "/api/facebook.py" },
    { "src": "/api/youtube",  "dest": "/api/youtube.py" },
    { "src": "/(.*)",         "dest": "/index.html" }
  ]
}
